# Copy this file to .env and fill in your values
# cp .env.example .env

# ── MySQL connection ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=chatbot_db
DB_PORT=3306

# ── LLM provider ─────────────────────────────────────────────────────────────
# Pick a provider and install its requirements file once:
#   pip install -r requirements-ollama.txt
#   pip install -r requirements-openai.txt
#   pip install -r requirements-anthropic.txt
#   pip install -r requirements-groq.txt
# Then only change the values below — no code changes needed.

LLM_PROVIDER=ollama

# Model name — must match the chosen provider's model identifier:
# ollama:    llama3.1, mistral, gemma2, ...  (run: ollama pull <model>)
# openai:    gpt-4o, gpt-4o-mini, ...
# anthropic: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001, ...
# groq:      llama-3.1-70b-versatile, mixtral-8x7b-32768, ...
LLM_MODEL=llama3.1

# API key — required for openai / anthropic / groq; leave blank for ollama
LLM_API_KEY=

# Base URL — required for ollama; optional for openai-compatible custom endpoints
LLM_BASE_URL=http://localhost:11434

# ── PDF library ───────────────────────────────────────────────────────────────
# Directory that contains PDF files (absolute or relative to project root)
PDF_DIR=./pdfs

# ChromaDB persists embeddings here; delete this folder to force a full re-index
CHROMA_DIR=./chroma_db

# ── Flask ─────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
SECRET_KEY=change-this-to-a-long-random-secret
