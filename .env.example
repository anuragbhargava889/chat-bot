# Copy this file to .env and fill in your values
# cp .env.example .env

# ── MySQL connection ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=chatbot_db
DB_PORT=3306

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default models
# LLM_FAST=claude-haiku-4-5    # used for quick classification tasks
# LLM_SMART=claude-opus-4-7    # used for reasoning + tool-use responses

# ── PDF library ───────────────────────────────────────────────────────────────
# Directory that contains PDF files (absolute or relative to project root)
PDF_DIR=./pdfs

# ChromaDB persists embeddings here; delete this folder to force a full re-index
CHROMA_DIR=./chroma_db

# ── Flask ─────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
SECRET_KEY=change-this-to-a-long-random-secret
