# Copy this file to .env and fill in your values
# cp .env.example .env

# ── MySQL connection ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=chatbot_db
DB_PORT=3306

# ── Ollama (open-source LLM) ──────────────────────────────────────────────────
# Install Ollama from https://ollama.com, then run: ollama pull llama3.1
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.1

# ── PDF library ───────────────────────────────────────────────────────────────
# Directory that contains PDF files (absolute or relative to project root)
PDF_DIR=./pdfs

# ChromaDB persists embeddings here; delete this folder to force a full re-index
CHROMA_DIR=./chroma_db

# ── Flask ─────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
SECRET_KEY=change-this-to-a-long-random-secret
